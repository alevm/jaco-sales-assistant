# VintageAgent — Environment Variables
#
# Copy this file to .env.local and fill in the values.
#
# For Sisyphus deployment: Andrea (infra operator) places .env.local on the VPS.
# See: onboarding-project-owner.md, Section 5.1

# Claude API key for image recognition and description generation.
# Ask Andrea whether to use a shared Anthropic key or provision a dedicated one for this project.
ANTHROPIC_API_KEY=

# SQLite database path (default is fine for most setups)
DB_PATH=./data/vintage.db
