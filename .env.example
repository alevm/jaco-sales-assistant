# VintageAgent — Environment Variables
#
# Copy this file to .env.local and fill in the values.
#
# For Sisyphus deployment: Andrea (infra operator) places .env.local on the VPS.
# See: onboarding-project-owner.md, Section 5.1

# --- Claude authentication ---
# The adapter in src/lib/claude.ts reads the auth-mode env var at request time and routes
# AI calls to one of two SDKs:
#   - subscription (default): @anthropic-ai/claude-agent-sdk with an OAuth token —
#     billed under the Claude Max subscription (the pot Andrea already pays for).
#   - api: @anthropic-ai/sdk with a prepaid key — billed under prepaid API credits
#     (a SEPARATE pot; do not use as the default).
# Flip modes by changing the value below and redeploying; no code change required.
CLAUDE_AUTH_MODE=subscription

# OAuth token for the Claude Max subscription (used when auth-mode = subscription).
CLAUDE_CODE_OAUTH_TOKEN=

# Prepaid API key (used when auth-mode = api; bills separately from the Max subscription).
ANTHROPIC_API_KEY=

# Secret token for API authentication. All /api/* requests must include
# Authorization: Bearer <this value>. Generate with: openssl rand -hex 32
API_SECRET=

# SQLite database path (default is fine for most setups)
DB_PATH=./data/vintage.db
